{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "npm run start -- -p 3001 -H 0.0.0.0",
      "startServerReadyPattern": "Ready",
      "url": ["http://127.0.0.1:3001/"],
      "settings": {
        "chromeFlags": "--headless=new --no-sandbox"
      }
    },
    "assert": {
      "preset": "lighthouse:recommended"
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
